# Backend configuration (monolith)
PORT=3001
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS configuration
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database configuration (used by docker-compose and all services)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=web_learn
DB_USER=root
DB_PASSWORD=dev_password

# File uploads (monolith)
UPLOADS_DIR=./uploads

# Microservices ports (optional overrides)
GATEWAY_PORT=3000
AUTH_PORT=3001
TOPIC_SPACE_PORT=3002
AI_PORT=3003

# Service discovery (for gateway)
AUTH_SERVICE_URL=http://localhost:3001
TOPIC_SPACE_SERVICE_URL=http://localhost:3002
AI_SERVICE_URL=http://localhost:3003

# AI configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Storage (optional)
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_ACCESS_KEY_SECRET=
STORAGE_CDN_BASE=